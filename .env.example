# API base URL for ShiftMate backend (port 8000 when running via docker-compose)
VITE_API_URL=http://localhost:8000

# ── App ──────────────────────────────────────────────────────────────────────
PROJECT_NAME="ShiftMate"
STACK_NAME=shift-mate
ENVIRONMENT=local

# ── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173"
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-me-with-a-real-secret-key
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=replace-me-with-a-strong-password

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Email (optional — leave blank to disable) ─────────────────────────────────
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# ── Sentry (optional — leave blank to disable) ────────────────────────────────
SENTRY_DSN=

# ── Docker image names ────────────────────────────────────────────────────────
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

RESEND_KEY=re_XXXXX
